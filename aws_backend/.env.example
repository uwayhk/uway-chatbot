# UWAY Chatbot Backend Environment Configuration
# Copy this to .env and fill in your credentials

# Gemini API Configuration
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# Alternative: Service Account Key (if API key disabled by org policy)
# GOOGLE_APPLICATION_CREDENTIALS=/opt/uway-chatbot/credentials.json

# Fallback Providers (uncomment if you have backup vendors)
# VENDOR1_ENDPOINT=https://api.vendor1.com/v1/chat
# VENDOR1_API_KEY=xxx
# VENDOR2_ENDPOINT=https://api.vendor2.com/v1/generate
# VENDOR2_API_KEY=xxx

# Redis Session Cache (optional, for production)
# REDIS_URL=redis://localhost:6379/0
